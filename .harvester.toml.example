# Harvester credentials — template (BILL-37).
#
# Copy this file to ~/.harvester.toml and fill in real tokens.
# The file lives at ~/.harvester.toml (machine-level, shared across all
# projects on this machine).  bin/slopstop-rag-start mounts it into the
# container automatically.
#
#     cp .harvester.toml.example ~/.harvester.toml
#     # edit ~/.harvester.toml, paste your token(s)
#
# These are READ-ONLY credentials: the harvesters only fetch tickets, never
# write to the source. Grant the minimum (read) scope. See
# design/ticket-rag.md § Harvester credentials for the exact click-through
# steps and scopes.
#
# NEVER commit ~/.harvester.toml.

# --- RAG service container --------------------------------------------------
# pgdata: host path for the Postgres data directory, bind-mounted into the
#         container. Survives container stop/restart; wipe pgdata/18/ to reset.
# image:  Docker image tag (default: slopstop-rag:latest).
[rag]
pgdata = "~/.local/share/slopstop/pgdata"
# image = "slopstop-rag:latest"

# --- Linear -----------------------------------------------------------------
# Personal API key, scope = Read. Workspace settings URL (swap <workspace>):
#   https://linear.app/<workspace>/settings/account/security
# Raw key in the Authorization header (NO "Bearer " prefix).
[linear]
api_key = "lin_api_xxxxxxxxxxxxxxxxxxxxxxxx"

# --- JIRA -------------------------------------------------------------------
# Scoped API token (read:jira-work, read:jira-user) from:
#   https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA uses HTTP Basic auth: <email>:<token>.
# project_keys is optional — auto-derived from .project-conf.toml prefix when
# running from a project directory (BILL-116).
[jira]
email     = "you@example.com"
api_token = "xxxxxxxxxxxxxxxxxxxxxxxx"
base_url  = "https://your-site.atlassian.net"
# project_keys = "PLTF"   # optional; omit to harvest all projects
