.DS_Store
*.swp
.idea/
.vscode/

# Python build / cache artifacts. Generated by pytest and the interpreter; never committed.
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Local dev virtualenv. Machine-local; never committed.
.venv/

# SCIP binary index files — intermediate artifacts produced by the SCIP indexers.
# Never committed.
*.scip
scratch/

# Project-local ticket tracking (tracking_dir = ".slopstop"). Holds the transient
# per-ticket task_plan/findings/progress dirs and their archive. Working state, not
# source — same treatment as scratch/.
.slopstop/
