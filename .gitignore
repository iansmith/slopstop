.DS_Store
*.swp
.idea/
.vscode/

# Python build / cache artifacts under rag-service/ (BILL-29). Generated by
# pytest and the interpreter; never committed.
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
# Local dev virtualenv for the host fast-test loop (see
# design/rag-service-testing.md § Running the tests). Machine-local; never committed.
.venv/

# Harvester credentials (BILL-37). `.harvester.toml` holds the per-source API
# tokens (Linear api_key, JIRA api_token, …) the harvester reads — a SECRET,
# never committed. The committed `.harvester.toml.example` documents the format.
# The harvester parses this file automatically; a matching env var
# (LINEAR_API_KEY) takes precedence, so the container/cron path can skip it.
.harvester.toml

# Runtime state for the postgres-pgvector container (BILL-12 / BILL-13).
# Mounted into the container; populated by initdb on first start.
# The empty directory itself is tracked via pgdata/.gitkeep so a fresh
# clone can `docker run` without first having to mkdir.
pgdata/*
!pgdata/.gitkeep

# BILL-15 — encoder/reranker model weights baked into the image. Pre-fetched
# on the host by fetch-models.sh into the build context, then COPYed into
# the image. ~4.5 GB; never committed.
docker/postgres-pgvector/models/

# SCIP binary index files — intermediate artifacts produced by scip-go/scip-python
# when run manually from the repo root. Never committed; slopstop-ingest writes
# these to a mktemp dir and removes them on exit.
*.scip
