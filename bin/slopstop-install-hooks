#!/usr/bin/env bash
# slopstop-install-hooks — Validate SCIP tool paths and install the
# slopstop post-merge git hook for one or more repositories.
#
# Usage:
#   slopstop-install-hooks [<repo-path> ...]
#
# If no <repo-path> is given, the current directory is used.
#
# Behaviour:
#   1. If ~/.slopstop/config.toml does not exist, creates a template and stops.
#      The user must fill in tool paths before re-running.
#   2. If the config exists but required tool paths for any repo are empty or
#      the binaries are not executable, prints which tools need configuring and
#      stops.  No hooks are installed in that case.
#   3. Resolves the slopstop-ingest binary on PATH (deferred past step 1 so
#      the config-template path works even before slopstop is on PATH).
#   4. If all required tools are configured, installs (or updates) the symlink:
#        <repo-path>/.git/hooks/post-merge → ~/.slopstop/hooks/post-merge
#      The shared hook script at ~/.slopstop/hooks/post-merge is created once.

set -uo pipefail

# shellcheck source=_slopstop-lib.sh
. "$(dirname "$0")/_slopstop-lib.sh"

SLOPSTOP_DIR="${HOME}/.slopstop"
SLOPSTOP_CONFIG="${SLOPSTOP_DIR}/config.toml"
SLOPSTOP_HOOKS_DIR="${SLOPSTOP_DIR}/hooks"
SLOPSTOP_HOOK="${SLOPSTOP_HOOKS_DIR}/post-merge"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log()    { printf '[slopstop-install-hooks] %s\n' "$*" >&2; }
err()    { printf '[slopstop-install-hooks] ERROR: %s\n' "$*" >&2; }
header() { printf '\n%s\n%s\n' "$*" "$(printf '%0.s─' $(seq 1 ${#1}))"; }

require_python3() {
    command -v python3 >/dev/null 2>&1 || { err "python3 not found on PATH"; exit 1; }
}

# ---------------------------------------------------------------------------
# Config template
# ---------------------------------------------------------------------------

CONFIG_TEMPLATE='# ~/.slopstop/config.toml
# Paths to SCIP indexer binaries on YOUR machine.
# Only fill in the tools you actually use; leave unused entries as empty strings.
# After editing, re-run: slopstop-install-hooks <repo-path>
#
# nvm/asdf/mise note: Node-managed binaries (scip-python, scip-typescript) live
# inside your version manager'"'"'s directory tree.  Provide the full resolved path,
# e.g. ~/.nvm/versions/node/v20.19.3/bin/scip-python — do not use "nvm exec".

[tools]
# go install github.com/sourcegraph/scip-go/cmd/scip-go@latest
scip_go = ""

# npm install -g @sourcegraph/scip-typescript
scip_typescript = ""

# npm install -g @sourcegraph/scip-python
scip_python = ""

# go install github.com/sourcegraph/scip/cmd/scip@latest  (used for JSON conversion)
scip = ""

[rag]
# URL of the running slopstop-rag container
url = "http://localhost:7777"
'

# ---------------------------------------------------------------------------
# Shared hook script (installed once at ~/.slopstop/hooks/post-merge)
# ---------------------------------------------------------------------------

# Find slopstop-ingest on PATH or relative to this script.
_resolve_ingest_binary() {
    # Try PATH first.
    if command -v slopstop-ingest >/dev/null 2>&1; then
        command -v slopstop-ingest
        return 0
    fi
    # Try sibling directory (repo checkout layout: bin/slopstop-install-hooks,
    # bin/slopstop-ingest are co-located).
    local script_dir
    script_dir="$(cd "$(dirname "$0")" && pwd -P)"
    if [ -x "$script_dir/slopstop-ingest" ]; then
        echo "$script_dir/slopstop-ingest"
        return 0
    fi
    return 1
}

# ---------------------------------------------------------------------------
# Step 1 — Create config template if absent
# ---------------------------------------------------------------------------

require_python3

if [ ! -f "$SLOPSTOP_CONFIG" ]; then
    mkdir -p "$SLOPSTOP_DIR"
    printf '%s' "$CONFIG_TEMPLATE" > "$SLOPSTOP_CONFIG"
    header "~/.slopstop/config.toml created"
    cat << 'MSG'
Fill in the tool paths for the languages your repos use, then re-run:

  slopstop-install-hooks <repo-path>

Example (macOS with Homebrew Go and nvm Node):
  [tools]
  scip_go        = "/Users/you/go/bin/scip-go"
  scip_python    = "/Users/you/.nvm/versions/node/v20.19.3/bin/scip-python"
  scip_typescript= "/Users/you/.nvm/versions/node/v20.19.3/bin/scip-typescript"
  scip           = "/Users/you/go/bin/scip"
MSG
    exit 0
fi

# ---------------------------------------------------------------------------
# Step 2 — Validate required tools for each requested repo
# ---------------------------------------------------------------------------

REPOS=()
if [ "$#" -eq 0 ]; then
    REPOS=("$(pwd)")
else
    REPOS=("$@")
fi

VALIDATION_FAILED=0

for repo in "${REPOS[@]}"; do
    repo="$(cd "$repo" && pwd -P 2>/dev/null)" || {
        err "repo path '$repo' not found"
        VALIDATION_FAILED=1
        continue
    }
    proj_conf="$repo/.project-conf.toml"
    if [ ! -f "$proj_conf" ]; then
        err "$repo: .project-conf.toml not found — is this a slopstop-managed repo?"
        VALIDATION_FAILED=1
        continue
    fi

    langs=()
    while IFS= read -r lang; do
        [ -n "$lang" ] && langs+=("$lang")
    done < <(toml_get_list "$proj_conf" "code-graph" "languages")

    if [ "${#langs[@]}" -eq 0 ]; then
        log "$repo: [code-graph].languages is empty — nothing to index"
        continue
    fi

    for lang in "${langs[@]}"; do
        key="$(_tool_key "$lang")" || {
            err "$repo: unsupported language '$lang'"
            VALIDATION_FAILED=1
            continue
        }
        tool_path="$(toml_get "$SLOPSTOP_CONFIG" "tools" "$key")"
        tool_path="${tool_path/#\~/$HOME}"
        if [ -z "$tool_path" ]; then
            err "$repo: [tools].$key is empty in ~/.slopstop/config.toml"
            err "  Install: $(_tool_install "$lang")"
            VALIDATION_FAILED=1
        elif [ ! -x "$tool_path" ]; then
            err "$repo: [tools].$key = '$tool_path' is not executable"
            VALIDATION_FAILED=1
        fi
    done
done

if [ "$VALIDATION_FAILED" -ne 0 ]; then
    echo ""
    echo "Fix the issues above, then re-run: slopstop-install-hooks ${REPOS[*]}"
    exit 1
fi

# ---------------------------------------------------------------------------
# Step 3 — Resolve ingest binary and build the shared hook script
# ---------------------------------------------------------------------------
# Deferred to here (past Step 1's config-template early exit) so that a
# first-time user without slopstop-ingest on PATH still gets the config
# template and instructions instead of an opaque "not found" error.

INGEST_BIN="$(_resolve_ingest_binary)" || {
    err "slopstop-ingest not found on PATH"
    err "Install slopstop and ensure its bin/ directory is on your PATH"
    exit 1
}

HOOK_BODY="#!/usr/bin/env bash
# .git/hooks/post-merge — managed by slopstop
# Update via: slopstop-install-hooks <repo-path>
# Do not add tool paths or logic here; those belong in ~/.slopstop/config.toml
exec '$INGEST_BIN' \"\$(git rev-parse --show-toplevel)\"
"

# ---------------------------------------------------------------------------
# Step 4 — Install (or update) the hook for each repo
# ---------------------------------------------------------------------------

mkdir -p "$SLOPSTOP_HOOKS_DIR"
printf '%s' "$HOOK_BODY" > "$SLOPSTOP_HOOK"
chmod +x "$SLOPSTOP_HOOK"

INSTALLED=0

for repo in "${REPOS[@]}"; do
    repo="$(cd "$repo" && pwd -P)"
    hook_target="$repo/.git/hooks/post-merge"
    hooks_dir="$repo/.git/hooks"

    if [ ! -d "$hooks_dir" ]; then
        err "$repo: .git/hooks/ not found — is this a git repository?"
        continue
    fi

    if [ -L "$hook_target" ] && [ "$(readlink "$hook_target")" = "$SLOPSTOP_HOOK" ]; then
        log "✓ $repo: post-merge hook already up to date"
        continue
    fi

    # Back up any existing hook that is not our symlink.
    if [ -e "$hook_target" ] && [ ! -L "$hook_target" ]; then
        mv "$hook_target" "${hook_target}.slopstop-backup"
        log "backed up existing hook to ${hook_target}.slopstop-backup"
    fi

    ln -sf "$SLOPSTOP_HOOK" "$hook_target"
    log "✓ $repo: post-merge hook installed"
    INSTALLED=$((INSTALLED + 1))
done

echo ""
log "done — $INSTALLED hook(s) installed"
log "Hooks point to: $SLOPSTOP_HOOK"
log "Config read from: $SLOPSTOP_CONFIG"
exit 0
