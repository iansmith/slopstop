#!/usr/bin/env bash
# slopstop-schedule-harvest — Print the crontab entry for nightly ticket-text harvest.
#
# Usage:
#   slopstop-schedule-harvest [<project-dir>]
#
# Reads [hooks].harvest_schedule, system, and key from .project-conf.toml in
# the given directory (default: cwd) and prints the cron entry that would
# schedule a nightly harvest.
#
# This script is READ-ONLY: it does not modify crontab or any config file.
# See "INSTALLING THE ENTRY" at the end of the output for how to add it.
#
# ── harvest_schedule format ────────────────────────────────────────────────
#   HH:MM          e.g. "02:00" — normalised to "MM HH * * *"
#   Cron expr      e.g. "0 2 * * *" — used verbatim (5 fields required)
#   "" or absent   disabled; this script prints an info message and exits 0
# ──────────────────────────────────────────────────────────────────────────

set -uo pipefail

# shellcheck source=_slopstop-lib.sh
. "$(dirname "$0")/_slopstop-lib.sh"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log() { printf '[slopstop-schedule-harvest] %s\n' "$*"; }
err() { printf '[slopstop-schedule-harvest] ERROR: %s\n' "$*" >&2; }

# ---------------------------------------------------------------------------
# Resolve full paths to host-side binaries
# ---------------------------------------------------------------------------
# Cron runs with a minimal PATH (/usr/bin:/bin on Linux; /usr/bin:/bin:/usr/sbin:/sbin
# on macOS). Neither docker nor a Homebrew python3 are in those paths.
# We resolve full paths NOW (at generation time on this machine) and embed them
# in the cron entry so the entry works regardless of cron's PATH.
#
# NOTE: python3 here is the HOST python3, used only to compute yesterday's date
# before calling docker exec. The python3 that runs the harvester module runs
# INSIDE the container (via docker exec) where the container's own PATH applies —
# that one is intentionally left as bare "python3".

DOCKER_BIN="$(command -v docker 2>/dev/null || true)"
PYTHON3_BIN="$(command -v python3 2>/dev/null || true)"

MISSING_TOOLS=()
[ -z "$DOCKER_BIN" ]  && MISSING_TOOLS+=("docker")
[ -z "$PYTHON3_BIN" ] && MISSING_TOOLS+=("python3")

if [ "${#MISSING_TOOLS[@]}" -gt 0 ]; then
    err "Cannot generate cron entry — the following tools are not on PATH:"
    for tool in "${MISSING_TOOLS[@]}"; do
        err "  $tool — install it and ensure it is on PATH, then re-run."
    done
    err ""
    err "  docker:  https://docs.docker.com/get-docker/"
    err "  python3: https://www.python.org/downloads/ or 'brew install python3'"
    exit 1
fi

# ---------------------------------------------------------------------------
# Resolve project directory and config
# ---------------------------------------------------------------------------

PROJECT_DIR="${1:-$(pwd)}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd -P 2>/dev/null)" || {
    err "project directory '$PROJECT_DIR' not found"
    exit 1
}
PROJECT_CONF="$PROJECT_DIR/.project-conf.toml"

if [ ! -f "$PROJECT_CONF" ]; then
    err ".project-conf.toml not found in '$PROJECT_DIR'"
    err "cd to a slopstop-managed project directory, or pass the path as an argument."
    exit 1
fi

# ---------------------------------------------------------------------------
# Read config values
# ---------------------------------------------------------------------------

SYSTEM="$(toml_get_top "$PROJECT_CONF" "system")"
KEY="$(toml_get_top "$PROJECT_CONF" "key")"
SCHEDULE="$(toml_get "$PROJECT_CONF" "hooks" "harvest_schedule")"

if [ -z "$SYSTEM" ]; then
    err "system field is missing or empty in .project-conf.toml"
    exit 1
fi

case "$SYSTEM" in
    linear|github|jira) ;;
    *)
        err "Unsupported system '$SYSTEM' — expected linear, github, or jira."
        exit 1
        ;;
esac

if [ -z "$SCHEDULE" ]; then
    log "harvest_schedule is not set (or is empty) in [hooks]."
    log ""
    log "To enable nightly harvest, add to .project-conf.toml:"
    log ""
    log "  [hooks]"
    log "  harvest_schedule = \"02:00\"   # local time HH:MM"
    log ""
    log "Then re-run: slopstop-schedule-harvest"
    exit 0
fi

# ---------------------------------------------------------------------------
# Normalise schedule → 5-field cron expression
# ---------------------------------------------------------------------------
# SCHEDULE_DESC is set in the same branch so both are computed from one regex.

if [[ "$SCHEDULE" =~ ^([0-9]{1,2}):([0-9]{2})$ ]]; then
    # HH:MM → "MM HH * * *"
    HOUR=$(( 10#${BASH_REMATCH[1]} ))
    MIN=$(( 10#${BASH_REMATCH[2]} ))
    if (( HOUR > 23 )); then
        err "Invalid hour '$HOUR' in harvest_schedule = '$SCHEDULE' (must be 0–23)."
        exit 1
    fi
    if (( MIN > 59 )); then
        err "Invalid minute '$MIN' in harvest_schedule = '$SCHEDULE' (must be 0–59)."
        exit 1
    fi
    CRON_EXPR="$MIN $HOUR * * *"
    SCHEDULE_DESC="daily at ${BASH_REMATCH[1]}:${BASH_REMATCH[2]} local time"
elif [[ "$SCHEDULE" =~ ^([^[:space:]]+[[:space:]]+){4}[^[:space:]]+$ ]]; then
    # Looks like a 5-field cron expression — use verbatim
    CRON_EXPR="$SCHEDULE"
    SCHEDULE_DESC="on schedule '${CRON_EXPR}'"
else
    err "Cannot parse harvest_schedule = '$SCHEDULE'."
    err "Use HH:MM (e.g. '02:00') or a 5-field cron expression (e.g. '0 2 * * *')."
    exit 1
fi

# ---------------------------------------------------------------------------
# Build the docker exec command for this system
# ---------------------------------------------------------------------------
# Design notes:
#   • Full paths to docker and python3 are embedded (resolved above) so the
#     entry works under cron's minimal PATH without any PATH= override.
#   • python3 here runs on the HOST to compute yesterday's date. The harvester
#     module runs inside the container via docker exec; that python3 is the
#     container's own and is intentionally left as bare "python3".
#   • Tokens are read from ~/.slopstop/<name> files at cron run time so the
#     actual secret never appears in the crontab entry.
#   • docker exec -e "VAR=$VAR" passes only the named variable, not the full
#     environment, so the container's process gets exactly what it needs.

CONTAINER="slopstop-rag"
LOG_FILE="\${HOME}/.slopstop/harvest.log"

# SINCE computation runs on the host using the fully-resolved python3 binary.
SINCE_EXPR="\$(${PYTHON3_BIN} -c \"from datetime import date,timedelta; print(date.today()-timedelta(days=1))\")"

# Build TOKEN_SETUP + EXEC_CMD for a single-token system (linear, github), which
# differ only in the env-var name, token file, and harvester module.
single_token_cmd() {
    local var="$1" token_file="$2" module="$3"
    TOKEN_SETUP="${var}=\$(cat ${token_file} 2>/dev/null)"
    EXEC_CMD="${DOCKER_BIN} exec -e \"${var}=\$${var}\" ${CONTAINER} python3 -m ${module} sync-recent --since \"\$SINCE\""
}

case "$SYSTEM" in
    linear)
        single_token_cmd "LINEAR_API_KEY" "~/.slopstop/linear_token" "rag_service.harvesters.linear"
        ;;
    github)
        single_token_cmd "GITHUB_TOKEN" "~/.slopstop/github_token" "rag_service.harvesters.github"
        ;;
    jira)
        TOKEN_SETUP="JIRA_EMAIL=\$(cat ~/.slopstop/jira_email 2>/dev/null); JIRA_API_TOKEN=\$(cat ~/.slopstop/jira_api_token 2>/dev/null); JIRA_BASE_URL=\$(cat ~/.slopstop/jira_base_url 2>/dev/null)"
        EXEC_CMD="${DOCKER_BIN} exec -e \"JIRA_EMAIL=\$JIRA_EMAIL\" -e \"JIRA_API_TOKEN=\$JIRA_API_TOKEN\" -e \"JIRA_BASE_URL=\$JIRA_BASE_URL\" ${CONTAINER} python3 -m rag_service.harvesters.jira sync-recent --since \"\$SINCE\""
        ;;
esac

FULL_CMD="SINCE=${SINCE_EXPR}; ${TOKEN_SETUP}; ${EXEC_CMD} >> ${LOG_FILE} 2>&1"

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

printf '\n'
printf '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n'
printf '  slopstop nightly harvest — %s (%s)\n' "$KEY" "$SYSTEM"
printf '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n'
printf '\n'
printf 'Schedule:  %s\n' "$SCHEDULE_DESC"
printf 'docker:    %s\n' "$DOCKER_BIN"
printf 'python3:   %s\n' "$PYTHON3_BIN"
printf '\n'
printf '── Crontab entry ───────────────────────────────────────────────\n'
printf '\n'
printf '# slopstop-harvest: %s\n' "$KEY"
printf '%s  %s\n' "$CRON_EXPR" "$FULL_CMD"
printf '\n'
printf '────────────────────────────────────────────────────────────────\n'
printf '\n'

# ---------------------------------------------------------------------------
# 1. PATH — what cron uses and how to change it
# ---------------------------------------------------------------------------

printf 'CRON PATH\n'
printf '\n'
printf '  Cron does NOT inherit your shell'"'"'s PATH. It uses a fixed minimal PATH:\n'
printf '\n'
printf '    Linux:  /usr/bin:/bin\n'
printf '    macOS:  /usr/bin:/bin:/usr/sbin:/sbin\n'
printf '\n'
printf '  The cron entry above uses full absolute paths (resolved on this machine\n'
printf '  right now) so it works without any PATH change:\n'
printf '    docker  → %s\n' "$DOCKER_BIN"
printf '    python3 → %s  (host only — computes yesterday'"'"'s date)\n' "$PYTHON3_BIN"
printf '\n'
printf '  If you prefer to set PATH in crontab instead (so all entries benefit),\n'
printf '  add this line at the very top of your crontab, before any entries:\n'
printf '\n'
# Build a deduplicated PATH suggestion from the resolved binary directories.
_DOCKER_DIR="$(dirname "$DOCKER_BIN")"
_PYTHON3_DIR="$(dirname "$PYTHON3_BIN")"
if [ "$_DOCKER_DIR" = "$_PYTHON3_DIR" ]; then
    _CRON_PATH="${_DOCKER_DIR}:/usr/bin:/bin"
else
    _CRON_PATH="${_DOCKER_DIR}:${_PYTHON3_DIR}:/usr/bin:/bin"
fi
printf '    PATH=%s\n' "$_CRON_PATH"
printf '\n'
printf '  Then you can replace the full paths above with bare "docker" and "python3".\n'
printf '  Only do this if you understand what other cron jobs run under that PATH.\n'
printf '\n'

# ---------------------------------------------------------------------------
# 2. Full paths needed
# ---------------------------------------------------------------------------

printf 'FULL PATHS REQUIRED IN THE CRON ENTRY\n'
printf '\n'
printf '  Two host-side binaries need full paths because cron'"'"'s PATH will not\n'
printf '  find them:\n'
printf '\n'
printf '    %-10s  %s\n' "docker" "$DOCKER_BIN"
printf '    %-10s  %s  (runs on the host to compute yesterday'"'"'s date)\n' "python3" "$PYTHON3_BIN"
printf '\n'
printf '  The harvester itself ("python3 -m rag_service.harvesters…") runs INSIDE\n'
printf '  the container via docker exec. That python3 is managed by the container'"'"'s\n'
printf '  own Dockerfile and PATH — you do not need to resolve it.\n'
printf '\n'
printf '  If you move to a different machine or reinstall docker/python3, re-run\n'
printf '  slopstop-schedule-harvest to get a fresh entry with updated paths.\n'
printf '\n'

# ---------------------------------------------------------------------------
# 3. Logs
# ---------------------------------------------------------------------------

printf 'LOGS\n'
printf '\n'
printf '  By default cron mails stdout+stderr to the local user via sendmail.\n'
printf '  On most developer machines sendmail is not configured, so output is\n'
printf '  silently discarded — you will never see errors or success messages.\n'
printf '\n'
printf '  The entry above redirects to:\n'
printf '    ~/.slopstop/harvest.log\n'
printf '\n'
printf '  This file is appended on every run. Rotate or truncate it periodically\n'
printf '  if you want to keep it small:\n'
printf '    # keep only the last 500 lines:\n'
printf '    tail -n 500 ~/.slopstop/harvest.log > /tmp/h.log && mv /tmp/h.log ~/.slopstop/harvest.log\n'
printf '\n'
printf '  Alternatives:\n'
printf '    >> /var/log/slopstop-harvest.log 2>&1   # system log dir (may need sudo)\n'
printf '    > /dev/null 2>&1                         # discard all output (silent failures)\n'
printf '\n'
printf '  To change the log path, edit the end of the cron command before pasting.\n'
printf '\n'

# ---------------------------------------------------------------------------
# Token files expected
# ---------------------------------------------------------------------------

printf 'TOKEN FILE(S) REQUIRED\n'
printf '  The cron command reads credentials from plain-text files at\n'
printf '  run time — the secrets are never stored in the crontab itself.\n'
printf '\n'
case "$SYSTEM" in
    linear)
        printf '  ~/.slopstop/linear_token   — your Linear API key (lin_api_…)\n'
        printf '  Create: echo "lin_api_YOUR_KEY" > ~/.slopstop/linear_token\n'
        printf '          chmod 600 ~/.slopstop/linear_token\n'
        ;;
    github)
        printf '  ~/.slopstop/github_token   — a GitHub personal access token\n'
        printf '  Create: echo "ghp_YOUR_TOKEN" > ~/.slopstop/github_token\n'
        printf '          chmod 600 ~/.slopstop/github_token\n'
        ;;
    jira)
        printf '  ~/.slopstop/jira_email      — your Atlassian account email\n'
        printf '  ~/.slopstop/jira_api_token  — your JIRA API token\n'
        printf '  ~/.slopstop/jira_base_url   — e.g. https://yourorg.atlassian.net\n'
        printf '  Create each with: echo "VALUE" > ~/.slopstop/jira_<file>\n'
        printf '                    chmod 600 ~/.slopstop/jira_<file>\n'
        ;;
esac
printf '\n'

# ---------------------------------------------------------------------------
# Crontab location — Unix and macOS
# ---------------------------------------------------------------------------

printf 'CRONTAB LOCATION\n'
printf '\n'
printf '  User crontabs are managed via the `crontab` command — never edit\n'
printf '  the underlying file directly, as the format is system-dependent.\n'
printf '\n'
printf '  Linux (Debian/Ubuntu):  /var/spool/cron/crontabs/<username>\n'
printf '  Linux (RHEL/Fedora):    /var/spool/cron/<username>\n'
printf '  macOS:                  /usr/lib/cron/tabs/<username>\n'
printf '                          (macOS Ventura+: /var/at/tabs/<username>)\n'
printf '\n'
printf '  On macOS, cron works but launchd is the native scheduler. A\n'
printf '  launchd plist (~/Library/LaunchAgents/) survives sleep/wake and\n'
printf '  runs missed jobs on wake. crontab is simpler to set up; use it\n'
printf '  for dev machines and consider launchd for always-on servers.\n'
printf '\n'

# ---------------------------------------------------------------------------
# Installing the entry
# ---------------------------------------------------------------------------

printf 'INSTALLING THE ENTRY\n'
printf '\n'
printf '  Open your crontab for editing:\n'
printf '    crontab -e\n'
printf '\n'
printf '  Or append non-interactively (preserves existing entries):\n'
printf '    (crontab -l 2>/dev/null; slopstop-schedule-harvest) | crontab -\n'
printf '\n'
printf '  Verify after installing:\n'
printf '    crontab -l | grep slopstop-harvest\n'
printf '\n'
printf '  To disable: remove the two lines (comment + command) from crontab,\n'
printf '  or set harvest_schedule = "" in .project-conf.toml and re-run:\n'
printf '    slopstop-schedule-harvest  (will print nothing to install)\n'
printf '\n'

exit 0
