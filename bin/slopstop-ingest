#!/usr/bin/env bash
# slopstop-ingest — Run SCIP indexers for a repo and POST the resulting graph
# to the slopstop-rag service.
#
# Usage:
#   slopstop-ingest [<repo-path>]
#
# <repo-path> defaults to the current git repository root.
#
# This script is called by the slopstop post-merge git hook.  It MUST exit 0
# in all cases where the failure is not the developer's fault (e.g., RAG
# container is down, network error) — never break `git merge` or `git pull`.
# It exits 1 only when the developer needs to take action (missing config,
# unconfigured tool paths).
#
# Config files read:
#   <repo-path>/.project-conf.toml    — [code-graph] languages, module_root
#   ~/.slopstop/config.toml           — [tools] scip_*, [rag] url
#
# Install:
#   See slopstop-install-hooks --help

set -uo pipefail

# shellcheck source=_slopstop-lib.sh
. "$(dirname "$0")/_slopstop-lib.sh"

SLOPSTOP_CONFIG="${HOME}/.slopstop/config.toml"
# Seconds before giving up on a POST; override with SLOPSTOP_INGEST_TIMEOUT=<n>.
MAX_TIME="${SLOPSTOP_INGEST_TIMEOUT:-180}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log()  { printf '[slopstop-ingest] %s\n' "$*" >&2; }
fail() { printf '[slopstop-ingest] ERROR: %s\n' "$*" >&2; exit 1; }
# Soft-fail: log a warning and exit 0 (don't break git workflows).
warn_exit() { printf '[slopstop-ingest] WARNING: %s — skipping ingest\n' "$*" >&2; exit 0; }

require_python3() {
    command -v python3 >/dev/null 2>&1 || fail "python3 not found on PATH"
}

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------

REPO_PATH="${1:-}"
if [ -z "$REPO_PATH" ]; then
    REPO_PATH="$(git rev-parse --show-toplevel 2>/dev/null)" \
        || fail "not inside a git repository and no <repo-path> given"
fi
REPO_PATH="$(cd "$REPO_PATH" && pwd -P)"

PROJECT_CONF="$REPO_PATH/.project-conf.toml"
[ -f "$PROJECT_CONF" ] || fail ".project-conf.toml not found in $REPO_PATH"

# ---------------------------------------------------------------------------
# Read project config
# ---------------------------------------------------------------------------

require_python3

LANGUAGES=()
while IFS= read -r lang; do
    [ -n "$lang" ] && LANGUAGES+=("$lang")
done < <(toml_get_list "$PROJECT_CONF" "code-graph" "languages")

if [ "${#LANGUAGES[@]}" -eq 0 ]; then
    warn_exit "[code-graph].languages is empty in $PROJECT_CONF"
fi

# module_root: directory (relative to repo root) where the indexer runs.
MODULE_ROOT="$(toml_get "$PROJECT_CONF" "code-graph" "module_root")"
MODULE_ROOT="${MODULE_ROOT:-.}"
INDEX_DIR="$REPO_PATH/$MODULE_ROOT"
[ -d "$INDEX_DIR" ] || fail "module_root '$MODULE_ROOT' is not a directory in $REPO_PATH"

# ---------------------------------------------------------------------------
# Read user config
# ---------------------------------------------------------------------------

if [ ! -f "$SLOPSTOP_CONFIG" ]; then
    fail "~/.slopstop/config.toml not found — run: slopstop-install-hooks $REPO_PATH"
fi

RAG_URL="$(toml_get "$SLOPSTOP_CONFIG" "rag" "url")"
RAG_URL="${RAG_URL:-http://localhost:7777}"

# ---------------------------------------------------------------------------
# Validate tool paths
# ---------------------------------------------------------------------------

# Parallel arrays: TOOL_LANGS[i] → TOOL_PATHS[i]
TOOL_LANGS=()
TOOL_PATHS=()

for lang in "${LANGUAGES[@]}"; do
    key="$(_tool_key "$lang")" || fail "unsupported language '$lang' in [code-graph].languages"
    tool_path="$(toml_get "$SLOPSTOP_CONFIG" "tools" "$key")"
    if [ -z "$tool_path" ]; then
        fail "$key not configured in ~/.slopstop/config.toml
  Install:  $(_tool_install "$lang")
  Then set: [tools]
            $key = \"/path/to/$(echo "$key" | tr '_' '-')\""
    fi
    tool_path="${tool_path/#\~/$HOME}"
    if [ ! -x "$tool_path" ]; then
        fail "$key = '$tool_path' is not executable
  Install:  $(_tool_install "$lang")
  Or fix:   [tools]
            $key = \"/correct/path/to/$(basename "$tool_path")\""
    fi
    TOOL_LANGS+=("$lang")
    TOOL_PATHS+=("$tool_path")
done

# Resolve the 'scip' CLI for binary → JSON conversion.
SCIP_CLI="$(toml_get "$SLOPSTOP_CONFIG" "tools" "scip")"
SCIP_CLI="${SCIP_CLI/#\~/$HOME}"
if [ -z "$SCIP_CLI" ] || [ ! -x "$SCIP_CLI" ]; then
    SCIP_CLI="$(command -v scip 2>/dev/null)" \
        || fail "'scip' CLI not found on PATH and [tools].scip not set in ~/.slopstop/config.toml
  Install: go install github.com/sourcegraph/scip/cmd/scip@latest
  Then add to config:
    [tools]
    scip = \"\$(which scip)\""
fi

# ---------------------------------------------------------------------------
# Derive repository identifier from git remote.
# ---------------------------------------------------------------------------

REPO_ID="$(git -C "$REPO_PATH" remote get-url origin 2>/dev/null \
    | sed 's/\.git$//' | awk -F'[/:]' '{print $(NF-1)"/"$NF}')"
if [ -z "$REPO_ID" ]; then
    REPO_ID="$(basename "$REPO_PATH")"
    log "no git remote 'origin'; using repo-id '$REPO_ID'"
fi

# ---------------------------------------------------------------------------
# Reconcile-on-start: skip if HEAD is already indexed (BILL-59).
# ---------------------------------------------------------------------------

HEAD_SHA="$(git -C "$REPO_PATH" rev-parse HEAD 2>/dev/null || echo "")"

if [ -n "$HEAD_SHA" ]; then
    STORED_SHA="$(curl -s --max-time 10 \
        "$RAG_URL/code-graph/repo/$REPO_ID" 2>/dev/null \
        | python3 -c \
            'import json,sys; d=json.load(sys.stdin); print(d.get("last_indexed_sha") or "")' \
            2>/dev/null || echo "")"
    if [ -n "$STORED_SHA" ] && [ "$STORED_SHA" = "$HEAD_SHA" ]; then
        log "already up to date (HEAD=${HEAD_SHA:0:12}) — skipping"
        exit 0
    fi
fi

# ---------------------------------------------------------------------------
# Index and ingest each language
# ---------------------------------------------------------------------------

TMPDIR_WORK="$(mktemp -d -t slopstop-ingest-XXXXXX)"
cleanup() { rm -rf "$TMPDIR_WORK"; }
trap cleanup EXIT

# Python wrapper: reads SCIP JSON from stdin, wraps it in the ingest envelope.
# argv[1] = repo_id, argv[2] = head_sha (optional — omitted when git HEAD unavailable).
WRAP_PY="$TMPDIR_WORK/wrap_payload.py"
cat > "$WRAP_PY" << 'PYEOF'
import json, sys

repo_id = sys.argv[1]
head_sha = sys.argv[2] if len(sys.argv) > 2 else None
try:
    index = json.load(sys.stdin)
except json.JSONDecodeError as e:
    print(f"ERROR: could not parse SCIP JSON: {e}", file=sys.stderr)
    sys.exit(1)
payload = {"repo": repo_id, "index": index}
if head_sha:
    payload["head_sha"] = head_sha
print(json.dumps(payload))
PYEOF

INGEST_OK=0

for i in "${!TOOL_LANGS[@]}"; do
    lang="${TOOL_LANGS[$i]}"
    tool="${TOOL_PATHS[$i]}"
    log "indexing '$lang' with $tool in $INDEX_DIR"

    SCIP_OUT="$TMPDIR_WORK/${lang}-index.scip"
    PAYLOAD_FILE="$TMPDIR_WORK/${lang}-payload.json"

    if ! (cd "$INDEX_DIR" && "$tool" index --output "$SCIP_OUT") 2>&1 \
            | sed "s/^/  [scip-${lang}] /" >&2; then
        log "SCIP indexer failed for '$lang' — skipping (run manually to debug)"
        continue
    fi

    if [ ! -f "$SCIP_OUT" ]; then
        log "indexer did not produce $SCIP_OUT — skipping"
        continue
    fi

    if ! "$SCIP_CLI" print --json "$SCIP_OUT" \
            | python3 "$WRAP_PY" "$REPO_ID" "$HEAD_SHA" > "$PAYLOAD_FILE"; then
        log "failed to convert $SCIP_OUT to JSON — skipping"
        continue
    fi

    PAYLOAD_BYTES="$(wc -c < "$PAYLOAD_FILE" | tr -d ' ')"
    log "POSTing ${PAYLOAD_BYTES} bytes to $RAG_URL/code-graph/ingest"

    CURL_EXIT=0
    HTTP_STATUS="$(curl -s --max-time "$MAX_TIME" \
        -w "%{http_code}" \
        -o "$TMPDIR_WORK/${lang}-response.json" \
        -X POST "$RAG_URL/code-graph/ingest" \
        -H "Content-Type: application/json" \
        --data-binary "@$PAYLOAD_FILE" 2>/dev/null)" || CURL_EXIT=$?

    if [ "$CURL_EXIT" -eq 28 ]; then
        log "ingest timed out after ${MAX_TIME}s — large repo?" \
            "Set SLOPSTOP_INGEST_TIMEOUT=<seconds> to allow more time"
    elif [ "$CURL_EXIT" -ne 0 ]; then
        log "RAG container not reachable at $RAG_URL (curl exit $CURL_EXIT)" \
            "— will retry on next post-merge"
    else
        case "$HTTP_STATUS" in
            200)
                RESP="$(cat "$TMPDIR_WORK/${lang}-response.json" 2>/dev/null)"
                log "ingest OK — $RESP"
                INGEST_OK=$((INGEST_OK + 1))
                ;;
            *)
                log "ingest returned HTTP $HTTP_STATUS — check $RAG_URL logs"
                ;;
        esac
    fi
done

if [ "$INGEST_OK" -gt 0 ]; then
    log "done — $INGEST_OK language(s) ingested"
else
    log "no languages successfully ingested (see warnings above)"
fi

exit 0  # never fail the git hook
